# URL absolue du backend (sans suffixe /api — ex. http://127.0.0.1:8000). Le client ajoute
# /api tout seul ; si vous aviez …/api dans l’URL, vous obteniez /api/api/… et des erreurs CORS.
# Si défini, le navigateur appelle l’API en cross-origin : l’origine du front doit être
# autorisée côté Laravel (CORS_ALLOWED_ORIGINS dans backend-api/.env).
# VITE_API_BASE_URL=http://127.0.0.1:8000

# En dev / vite preview, proxy /api → ce serveur (php artisan serve --port=…).
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
